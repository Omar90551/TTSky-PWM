[options]
mode cover

[engines]
smtbmc

[script]
read -formal pwm_counter.v
prep -top pwm_counter

[file pwm_counter.v]
`default_nettype none

module pwm_counter (
    input  wire       clk,
    input  wire       rst_n,
    input  wire       enable,
    input  wire [7:0] period_cfg,
    output reg  [7:0] count_out
);

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            count_out <= 8'd0;
        end else if (!enable) begin
            count_out <= 8'd0;
        end else begin
            if (count_out >= period_cfg) begin
                count_out <= 8'd0;
            end else begin
                count_out <= count_out + 8'd1;
            end
        end
    end

    `ifdef FORMAL
        reg f_past_valid = 1'b0;
        always @(posedge clk) f_past_valid <= 1'b1;

        // REQ-07: Async reset — check AFTER the clock edge that captured the reset
        always @(posedge clk) begin
            if (f_past_valid && !$past(rst_n))
                assert(count_out == 8'd0);
        end

        // REQ-06: Sync disable — counter must be 0 after enable was low
        // REQ-02: Counter must never exceed period_cfg
        always @(posedge clk) begin
            if (f_past_valid && $past(rst_n)) begin
                if (!$past(enable))
                    assert(count_out == 8'd0);
                if ($past(enable) && $past(period_cfg) > 0)
                    assert(count_out <= $past(period_cfg));
            end
        end

        // COVER: Can the counter actually reach 10?
        always @(posedge clk) begin
            if (rst_n && enable && period_cfg == 8'd10)
                cover(count_out == 8'd10);
        end
    `endif

endmodule
